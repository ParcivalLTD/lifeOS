# Copy to .env.local and fill in. .env* files are gitignored (except this one).

# --- App ------------------------------------------------------------------------
# The app's public URL (scheme + host, no trailing path). Used as the base for
# auth/proxy redirect Location headers so they point at the real origin when
# the app runs behind a reverse proxy (e.g. Traefik). Falls back to the
# request URL when unset.
NEXT_PUBLIC_SITE_URL=https://lifeos.example.com

# --- Supabase (auth + Postgres) ------------------------------------------------
# Hosted: Project Settings → API. Local stack (`npx supabase start`): printed
# by `npx supabase status`.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — never expose with a NEXT_PUBLIC_ prefix. Used exclusively by
# scripts/create-owner.ts (admin API); the app never reads it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Postgres connection for Drizzle (migrations, seed, server queries) --------
# Hosted Supabase: Project Settings → Database → Connection string (URI).
# Local Supabase stack: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Plain local Postgres (needs `npm run db:shim` once): see README.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Owner account (single user — no sign-up flow, spec NG1) --------------------
# Consumed by `npm run auth:create-owner`.
OWNER_EMAIL=you@example.com
OWNER_PASSWORD=choose-a-strong-password

# The auth.users id rows are seeded under. Take it from create-owner's output.
# Optional on shim-based plain Postgres (a fixed UUID is used).
# SEED_USER_ID=

# --- AI layer (Phase 4, NFR-1) ---------------------------------------------------
# Server-only — never expose with a NEXT_PUBLIC_ prefix (same rule as the
# service-role key). Read exclusively by src/lib/ai/client.ts, the single code
# path allowed to call the Anthropic API. Optional: without it the AI layer is
# disabled; the /settings/ai-preview audit page works regardless (it never sends).
# ANTHROPIC_API_KEY=

# --- Nightly backup (NFR-4) -----------------------------------------------------
# Vercel Cron calls GET /api/backup with `Authorization: Bearer $CRON_SECRET`.
# Set the same value in the Vercel project env. Any long random string.
CRON_SECRET=generate-a-long-random-string
