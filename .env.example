# Copy to .env.local and fill in. .env* files are gitignored (except this one).

# --- Supabase (auth + hosted Postgres) ---------------------------------------
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Postgres connection for Drizzle (migrations, seed, server queries) ------
# Supabase: Project Settings → Database → Connection string (URI).
# Local dev container (see README "Local database"):
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:54329/lifeos

# --- Seed ---------------------------------------------------------------------
# The auth.users id rows are seeded under. Optional locally (a fixed UUID is
# used); set it to the owner account's id when seeding a Supabase project.
# SEED_USER_ID=
