# Copy to .env.local and fill in. .env* files are gitignored (except this one).

# --- App ------------------------------------------------------------------------
# The app's public URL (scheme + host, no trailing path). Used as the base for
# auth/proxy redirect Location headers so they point at the real origin when
# the app runs behind a reverse proxy (e.g. Traefik). Falls back to the
# request URL when unset.
NEXT_PUBLIC_SITE_URL=https://lifeos.example.com

# --- Supabase (auth + Postgres) ------------------------------------------------
# Hosted: Project Settings → API. Local stack (`npx supabase start`): printed
# by `npx supabase status`.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Server-only — never expose with a NEXT_PUBLIC_ prefix. Used exclusively by
# scripts/create-owner.ts (admin API); the app never reads it.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Postgres connection for Drizzle (migrations, seed, server queries) --------
# Hosted Supabase: Project Settings → Database → Connection string (URI).
# Local Supabase stack: postgresql://postgres:postgres@127.0.0.1:54322/postgres
# Plain local Postgres (needs `npm run db:shim` once): see README.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# --- Owner account (single user — no sign-up flow, spec NG1) --------------------
# Consumed by `npm run auth:create-owner`.
OWNER_EMAIL=you@example.com
OWNER_PASSWORD=choose-a-strong-password

# The auth.users id rows are seeded under. Take it from create-owner's output.
# Optional on shim-based plain Postgres (a fixed UUID is used).
# SEED_USER_ID=

# --- AI layer (Phase 4, NFR-1) ---------------------------------------------------
# Multi-provider: Claude, ChatGPT, Gemini. Each key is read ONLY by that
# provider's adapter in src/lib/ai/providers/ — the single code path allowed to
# call that vendor's API. Server-only: never expose with a NEXT_PUBLIC_ prefix
# (same rule as the service-role key).
#
# All three are optional and independent. A provider WITHOUT a key is simply
# hidden from the model picker — it is never an error. With no key at all the
# AI layer is disabled; /settings/ai-preview still works (it never sends).
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
#
# The model is chosen in Settings -> Assistant model and saved there.
# Gemini's configured tiers are free-tier eligible; note that Google's free
# tier permits them to use submitted content to improve their products.

# --- Nightly backup (NFR-4) -----------------------------------------------------
# A Coolify Scheduled Task calls GET /api/backup with
# `Authorization: Bearer $CRON_SECRET`. Any long random string.
CRON_SECRET=generate-a-long-random-string

# --- Apple Calendar sync (iCloud -> Helm, one way) -------------------------------
# Encrypts the stored app-specific password at rest. Server-only, same secrecy
# standard as the service-role key: it is the ONLY thing standing between a
# database dump and the credential. Must decode to exactly 32 bytes.
#   openssl rand -base64 32
# Without it the Apple Calendar panel in Settings stays disabled.
# CALDAV_ENCRYPTION_KEY=

# Bearer token for GET /api/sync/apple-calendar, called every 15 minutes by a
# Coolify Scheduled Task (see README). Any long random string.
#   openssl rand -hex 32
# CALDAV_SYNC_SECRET=

# Test-only: point the CalDAV client at a mock server instead of iCloud.
# Leave unset in every real environment.
# CALDAV_BASE_URL=
